<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TFG_FranciscoCarreroCarrero_7WondersArchitects.Presentation.HelpPopup">
    <HorizontalStackLayout Spacing="15">
        <VerticalStackLayout Spacing="5">
            <Label Text="Reglas"
                FontSize="13"
                HorizontalTextAlignment="Center" />
            <ImageButton 
              Aspect="AspectFit"
              Source="imagenes/logo_pdf.png"
              CornerRadius="15"
              WidthRequest="60"
              HeightRequest="60"
              Padding="4"
              Clicked="GoToRules"/>
        </VerticalStackLayout>

        <VerticalStackLayout Spacing="5">
            <Label Text="Video"
                 FontSize="13"
                 HorizontalTextAlignment="Center" />
            <ImageButton 
              Aspect="AspectFit"
              Source="imagenes/logo_youtube.png"
              CornerRadius="15"
              WidthRequest="60"
              HeightRequest="60"
              Padding="3,0,3,0"
              Clicked="GoToVideo"/>
        </VerticalStackLayout>
    </HorizontalStackLayout>
</toolkit:Popup>
